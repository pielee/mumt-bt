<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="mumt-manned-formation">

    <!-- ===== F16_UAV1 : 자체 이륙 → 유인기(M_F16) 슬롯 편대 (계층형 유도 → UE PID 내루프) =====
         슬롯 = 리더 뒤 80m · 우측 100m · 동일 고도. FormationGuidance가 heading/alt/speed/roll_ff
         명령을 산출하고 UE 내루프가 추종. GetStick(조준) 대체 — 선회 편대 가능(roll_ff 피드포워드).
         전제: 제어기 교체 UE 빌드 + custom_msgs 재빌드(roll_ff_deg). 유인기는 조이스틱 조종. -->
    <ReactiveSequence>
      <GatherState own_name="F16_UAV1" leader_name="M_F16"/>
      <FormationGuidance own_name="F16_UAV1" leader_name="M_F16"
                         front_m="-80" right_m="100" up_m="0"
                         min_speed_mps="70" max_speed_mps="335"
                         runway_heading_deg="90" takeoff_forward_m="3000" takeoff_up_m="800"
                         takeoff_speed_mps="220" takeoff_climb_m="150" min_agl_m="150" bt_rate_hz="10"/>
    </ReactiveSequence>

  </BehaviorTree>
</root>
