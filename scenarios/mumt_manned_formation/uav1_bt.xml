<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="mumt-manned-formation">

    <!-- ===== F16_UAV1 : 자체 이륙 → 유인기(M_F16) 슬롯 편대 (Phase 4: 인엔진 유도) =====
         슬롯 = 리더 뒤 80m · 우측 100m · 동일 고도. BT는 이륙(direct) 후
         guidance_mode="formation"만 발행 — 슬롯·ω×r·벡터필드·roll_ff 계산은 UE가
         리더 pawn 직독으로 60Hz 수행 (V1 폐루프: 3°/s 4.5m, 5°/s+상승 12.5m).
         전제: Phase 4 UE 빌드 + custom_msgs 재빌드(guidance_mode). 유인기는 조이스틱. -->
    <ReactiveSequence>
      <GatherState own_name="F16_UAV1" leader_name="M_F16"/>
      <FormationGuidance own_name="F16_UAV1" leader_name="M_F16"
                         front_m="-80" right_m="100" up_m="0"
                         min_speed_mps="70" max_speed_mps="335"
                         runway_heading_deg="90" takeoff_forward_m="3000" takeoff_up_m="800"
                         takeoff_speed_mps="220" takeoff_climb_m="150" min_agl_m="150" bt_rate_hz="10"/>
    </ReactiveSequence>

  </BehaviorTree>
</root>
