<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="mumt">

    <!-- ===== UAV1 = F16_UAV1 : 리더 앞 '좌측' 편대 =====
         own_name = UE 아웃라이너 라벨(GetActorLabel) 기준. 에디터에서 이 기체 라벨을 F16_UAV1 로.
         own_name 을 모든 노드에 F16_UAV1 로 명시(공유 토픽에서 이 기체만 조종).
         슬롯: aft_offset_m=-80 (리더 앞 80m), lateral_offset_m=-40 (좌측 40m).
         UAV2(우측)는 uav2_bt.xml. -->
    <ReactiveSequence>
      <GatherState own_name="F16_UAV1" leader_name="M_F16"/>
      <Sequence>
        <WaitForLeaderTakeoff leader_airborne_climb_m="80" own_name="F16_UAV1"/>
        <Takeoff runway_heading_deg="90" climb_target_m="1000" uav_airborne_climb_m="200" own_name="F16_UAV1"/>
        <MaintainFormation own_name="F16_UAV1" aft_offset_m="-80" lateral_offset_m="-40" vertical_offset_m="0"
                           blend_radius_m="300" kp_speed="0.05"/>
      </Sequence>
    </ReactiveSequence>

  </BehaviorTree>
</root>
